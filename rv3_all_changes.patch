+            1092 if tlv_len == 4 => {
+                attr.link_metric_te = Some(u32::from_be_bytes([data[0], data[1], data[2], data[3]]));
+            }
+            // TLV 1094: SRLG (Shared Risk Link Group) — array of u32
+            1094 => {
+                let mut i = 0;
+                while i + 4 <= data.len() {
+                    attr.srlg.push(u32::from_be_bytes([data[i], data[i+1], data[i+2], data[i+3]]));
