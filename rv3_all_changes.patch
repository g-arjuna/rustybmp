+            1156 if tlv_len == 4 => {
+                attr.ospf_fwd_addr = Some(IpAddr::V4(Ipv4Addr::from([data[0], data[1], data[2], data[3]])));
+            }
+            1156 if tlv_len == 16 => {
+                let mut b = [0u8; 16]; b.copy_from_slice(data);
