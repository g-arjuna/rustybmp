# rustybmp configuration — copy to rustybmp.toml and edit

[bmp]
# TCP address to listen for BMP sessions (RFC 7854)
listen_addr      = "0.0.0.0:5000"
# Maximum BMP frame size in bytes (protect against memory exhaustion)
max_frame_bytes  = 65535
# Drop Statistics Report messages under backpressure (keep Route Monitoring)
shed_stats_on_pressure = true
# Optional: write every BMP message as JSON-Lines for audit/replay
# archive_path = "runtime/bmp.jsonl"

[http]
# REST API + SSE + UI bind address
listen_addr = "0.0.0.0:7878"
# Serve the embedded Svelte UI at /
serve_ui    = true
# CORS allowed origins (empty = allow all; add origins for production)
# cors_origins = ["https://your-dashboard.example.com"]

[store]
# DuckDB database path (directory created automatically)
db_path        = "runtime/routes.duckdb"
# Use in-memory DuckDB only (no persistence — useful for testing)
in_memory      = false
# Internal event channel depth (increase for high-volume environments)
event_capacity = 16384
# Flush DuckDB WAL to disk every N seconds (0 = every write)
checkpoint_secs = 60

[log]
# Log level: trace | debug | info | warn | error
level  = "info"
# Log format: pretty | json
format = "pretty"

[rpki]
# Enable RPKI RTR client for route origin validation (RFC 8210)
enabled  = false
# RTR server address — Routinator default: 127.0.0.1:3323
#                      rpki-client default: 127.0.0.1:3323
rtr_addr = "127.0.0.1:3323"

[store]
# Delete events older than N days (0 = keep forever)
retain_days = 90

[tls]
# Enable TLS for the BMP TCP listener (RV4-1 T2)
# Routers/collectors connect via TLS instead of plain TCP.
enabled       = false
cert_pem      = "certs/server.pem"
key_pem       = "certs/server.key"
# Optional: require mTLS from connecting clients
# client_ca_pem = "certs/ca.pem"

[ha]
# Active/passive HA via Redis SETNX leader lease (RV4-7 T1)
# Both instances collect; only the leader writes to DuckDB + serves HTTP API.
enabled     = false
redis_url   = "redis://localhost:6379"
instance_id = "core-1"
lease_secs  = 10

# ── Filter expression language (RV5-1) ───────────────────────────────────────
# Path to YAML filter file. Hot-reloaded on save — no restart needed.
# Supports PEG expressions: "rpki == 'invalid' AND prefix_len > 24"
# filter_file = "config/filters.yaml"

[registry]
# Known BMP speaker metadata — enriches /api/speakers with hostname/vendor/site
# [[registry.speakers]]
# addr     = "192.0.2.1"
# hostname = "xr-spine-01"
# vendor   = "cisco-xr"
# site     = "dc-lon-01"

# ── Resource Governor (RV8-GOV1/GOV3) ────────────────────────────────────────
# Three-loop resource governor: memory pressure, write queue pressure, rate governance.
# Tune these for internet-scale MRT injection (~36K routes/sec).
[governor]
# Memory budget in MB. Default: 8 GB. Increase for internet table injection (12GB for 32GB machine).
memory_budget_mb = 8000
# Maximum inbound events/second before rate shedding activates (shed BMP stats/BGP-LS updates first).
rate_budget_eps  = 500000
# BMP message types that can be shed under pressure (stats = BMP Stats Reports §4.8)
sheddable_types  = ["stats"]

# ── Internet-scale DuckDB write tuning (RV8-GOV3) ─────────────────────────────
# For full RouteViews MRT table injection (~1.1M prefixes, ~36K routes/sec):
#   batch_size        = 5000    # increase from default 500
#   batch_timeout_ms  = 200     # increase from default 50ms — fewer DuckDB transactions
#   write_queue_depth = 100000  # increase channel depth from default 16384
#
# Uncomment and adjust for your workload:
# [store.write]
# batch_size        = 5000
# batch_timeout_ms  = 200
# write_queue_depth = 100000

# ── Output Adapters (RV8-OUT1) ────────────────────────────────────────────────
# Uncomment and configure to forward BGP events to external sinks.
# [output.elasticsearch]
# url   = "http://localhost:9200"
# index = "bgp-events"
# # api_key = "base64encodedkey"   # OR: username/password below
# # username = "elastic"
# # password = "changeme"

# [output.splunk]
# url        = "https://splunk-host:8088"
# token      = "your-hec-token"
# index      = "main"
# sourcetype = "bgp:rustybmp"
# insecure_tls = false
