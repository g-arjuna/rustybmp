# rustybmp configuration — copy to rustybmp.toml and edit

[bmp]
# TCP address to listen for BMP sessions (RFC 7854)
listen_addr      = "0.0.0.0:5000"
# Maximum BMP frame size in bytes (protect against memory exhaustion)
max_frame_bytes  = 65535
# Drop Statistics Report messages under backpressure (keep Route Monitoring)
shed_stats_on_pressure = true
# Optional: write every BMP message as JSON-Lines for audit/replay
# archive_path = "runtime/bmp.jsonl"

[http]
# REST API + SSE + UI bind address
listen_addr = "0.0.0.0:7878"
# Serve the embedded Svelte UI at /
serve_ui    = true
# CORS allowed origins (empty = allow all; add origins for production)
# cors_origins = ["https://your-dashboard.example.com"]

[store]
# DuckDB database path (directory created automatically)
db_path        = "runtime/routes.duckdb"
# Use in-memory DuckDB only (no persistence — useful for testing)
in_memory      = false
# Internal event channel depth (increase for high-volume environments)
event_capacity = 16384
# Flush DuckDB WAL to disk every N seconds (0 = every write)
checkpoint_secs = 60

[log]
# Log level: trace | debug | info | warn | error
level  = "info"
# Log format: pretty | json
format = "pretty"
