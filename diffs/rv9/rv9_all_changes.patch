+        XR_EVERY_BOOT_CONFIG: /etc/xrd/startup.cfg
+
+  links:
+    # PE1 ↔ PE2 (iBGP backbone)
+    - endpoints: ["pe1:Gi0-0-0-0", "pe2:Gi0-0-0-0"]
