+            writer::BgpState::Active, writer::BgpState::Established,
+        ).unwrap();
+        let mut cursor = std::io::Cursor::new(&buf);
+        let record = read_record(&mut cursor).unwrap().unwrap();
+        assert!(record.is_bgp4mp(), "BGP4MP record must report is_bgp4mp()=true");
