+            &bgp_bytes,
+        ).unwrap();
+        let mut cursor = std::io::Cursor::new(&buf);
+        let record = read_record(&mut cursor).unwrap().unwrap();
+        let (hdr, _) = parse_bgp4mp_message(&record.body).unwrap();
