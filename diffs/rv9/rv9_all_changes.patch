new file mode 100644
index 0000000..abe3f5e
--- /dev/null
+++ b/tests/scenarios/01_frr_minimal/topology.clab.yml
@@ -0,0 +1,50 @@
+name: frr-minimal-smoke
+
+mgmt:
+  network: frr-smoke-mgmt
+  ipv4-subnet: 172.20.20.0/24
+
+topology:
+  nodes:
+
+    # ── rustybmp BMP collector ───────────────────────────────────────────────
+    collector:
+      kind: linux
+      image: rustybmp:latest
+      binds:
+        - ./configs/rustybmp.toml:/etc/rustybmp/rustybmp.toml:ro
+      ports:
+        - "15000:5000"   # BMP listener
+        - "17878:7878"   # HTTP API
+      env:
+        RUST_LOG: info,rbmp_server=debug
+
+    # ── FRR router 1 (iBGP speaker, BMP sender) ─────────────────────────────
+    frr1:
+      kind: linux
+      image: quay.io/frrouting/frr:10.6.1
+      binds:
+        - ./configs/frr1.conf:/etc/frr/frr.conf:ro
+        - ./configs/daemons:/etc/frr/daemons:ro
+      env:
+        TINI_SUBREAPER: "1"
+      exec:
+        - /bin/bash /etc/frr/start.sh
+
+    # ── FRR router 2 (iBGP peer, also sends BMP) ────────────────────────────
+    frr2:
+      kind: linux
