+            &mut buf, &ts(), 64512, 65000, 0,
+            "10.1.1.1".parse().unwrap(), "10.1.1.2".parse().unwrap(),
+            &bgp_bytes,
+        ).unwrap();
+        let mut cursor = std::io::Cursor::new(&buf);
