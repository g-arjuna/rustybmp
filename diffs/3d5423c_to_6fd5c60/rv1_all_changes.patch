+        self._client = httpx.AsyncClient(base_url=self.base_url, timeout=self._timeout)
+        return self
+
+    async def __aexit__(self, *_):
+        if self._client:
+            await self._client.aclose()
+
+    async def health(self) -> dict:
+        r = await self._client.get("/health")
+        r.raise_for_status()
+        return r.json()
