+                addr[..octets].copy_from_slice(&chunk);
+                let net = Ipv4Net::new(Ipv4Addr::from(addr), prefix_len)
+                    .map_err(|_| Error::InvalidPrefixLen { prefix_len, afi: afi.as_u16() })?;
